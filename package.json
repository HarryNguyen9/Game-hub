{
  "name": "game-hub",
  "version": "1.0.0",
  "description": "A cute responsive multiplayer game hub MVP with custom auth, Supabase, and Socket.IO.",
  "main": "server/index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:socket:dev\"",
    "dev:web": "next dev",
    "socket:dev": "tsx server/index.ts",
    "build": "next build",
    "start": "next start",
    "socket:start": "tsx server/index.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "seed:admin": "tsx scripts/seed-admin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.3",
    "chess.js": "^1.4.0",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "vitest": "^4.1.7"
  }
}
